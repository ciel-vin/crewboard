# Copy to `.env.local` and paste your Supabase project values (Settings → API).
# The two NEXT_PUBLIC_ values are safe for the browser. Never expose the service_role key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Optional (server-only, keep secret) — not required for the demo:
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
